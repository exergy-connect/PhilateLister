{
  "manifest_version": 3,
  "name": "PhilateLister Image Analyzer",
  "description": "Right-click a stamp image and open AI listing analysis or OpenCV centering analysis.",
  "version": "0.1.0",
  "permissions": ["contextMenus", "tabs", "storage", "unlimitedStorage"],
  "host_permissions": ["<all_urls>"],
  "externally_connectable": {
    "matches": [
      "https://exergy-connect.github.io/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
