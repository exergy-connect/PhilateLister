    <th>{{ event.hours[2].day }}</th>
  </tr>
  <tr>
    <td>{{ event.hours[0].time }}</td>
    <td>{{ event.hours[1].time }}</td>
    <td>{{ event.hours[2].time }}</td>
  </tr>
</table>

